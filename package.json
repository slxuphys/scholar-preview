{
  "name": "scholar-preview",
  "displayName": "Scholar Preview",
  "description": "Live notebook preview with Typst export, citation auto-fetch (DOI/arXiv), cross-references, and bibliography generation.",
  "version": "0.1.1",
  "publisher": "slxuphys",
  "repository": {
    "type": "git",
    "url": "https://github.com/slxuphys/scholar-preview"
  },
  "bugs": {
    "url": "https://github.com/slxuphys/scholar-preview/issues"
  },
  "homepage": "https://github.com/slxuphys/scholar-preview#readme",
  "icon": "images/icon.png",
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "scholarPreview.openSidepanePreview",
        "category": "Scholar Preview",
        "title": "Open HTML Preview"
      },
      {
        "command": "scholarPreview.toggleFollowActiveCell",
        "category": "Scholar Preview",
        "title": "Toggle Follow Active Cell"
      },
      {
        "command": "scholarPreview.refreshPreview",
        "category": "Scholar Preview",
        "title": "Refresh Preview"
      },
      {
        "command": "scholarPreview.openTypstPreview",
        "category": "Scholar Preview",
        "title": "Open Typst Preview"
      }
    ],
    "menus": {
      "commandPalette": [
        {
          "command": "scholarPreview.openSidepanePreview"
        },
        {
          "command": "scholarPreview.toggleFollowActiveCell"
        },
        {
          "command": "scholarPreview.refreshPreview"
        },
        {
          "command": "scholarPreview.openTypstPreview"
        }
      ],
      "editor/title": [
        {
          "command": "scholarPreview.openSidepanePreview",
          "group": "navigation@10",
          "when": "editorLangId == markdown"
        }
      ],
      "notebook/title": [
        {
          "command": "scholarPreview.openSidepanePreview",
          "group": "navigation@10"
        },
        {
          "command": "scholarPreview.openTypstPreview",
          "group": "navigation@11"
        }
      ]
    },
    "configuration": {
      "title": "Scholar Preview",
      "properties": {
        "scholarPreview.followActiveCell": {
          "type": "boolean",
          "default": true,
          "description": "Auto-scroll the preview to the active notebook cell."
        },
        "scholarPreview.math.renderer": {
          "type": "string",
          "enum": [
            "katex",
            "none"
          ],
          "default": "katex",
          "description": "Math renderer used in preview markdown cells."
        },
        "scholarPreview.math.katexTrust": {
          "type": "boolean",
          "default": false,
          "description": "Enable trusted KaTeX rendering features. Keep disabled unless required."
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile",
    "lint": "echo \"Add linter setup\""
  },
  "devDependencies": {
    "@resvg/resvg-js": "^2.6.2",
    "@types/node": "^20.12.12",
    "@types/vscode": "^1.90.0",
    "typescript": "^5.6.3"
  },
  "dependencies": {
    "highlight.js": "^11.11.1",
    "katex": "^0.16.45"
  }
}
